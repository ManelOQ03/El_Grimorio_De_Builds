<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}El Grimorio De Builds{% endblock %}</title>

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>

    <body>

        <nav class="navbar">

            <a href="{{ path('app_home') }}" class="logo">
                <img src="{{ asset('images/logo.png') }}" alt="Logo">
                Inicio
            </a>

            {% if app.user %}

                <a href="{{ path('user_profile', {'username': app.user.username}) }}">
                    Perfil
                </a>

                <a href="{{ path('app_profile_edit') }}">
                    Editar perfil
                </a>

                <span>
                    👤 {{ app.user.username }}
                </span>

                <a href="{{ path('app_logout') }}">
                    Cerrar sesión
                </a>

            {% else %}

                <a href="{{ path('app_login') }}">
                    Iniciar sesión
                </a>

                <a href="{{ path('app_register') }}">
                    Registrarse
                </a>

            {% endif %}

        </nav>

        {% block banner %}{% endblock %}

        <div class="container">
            {% block body %}{% endblock %}
        </div>

    </body>
</html>
