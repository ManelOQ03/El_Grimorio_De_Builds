{% extends 'base.html.twig' %}

{% block title %}
    {{ post.title }}
{% endblock %}

{% block banner %}
    <div class="game-banner">
        <img
            src="/uploads/banners/{{ post.game.bannerImage }}"
            alt="{{ post.game.name }}"
        >
    </div>
{% endblock %}

{% block body %}

<h1>{{ post.title }}</h1>

<p>
    Juego:
    {{ post.game.name }}
</p>

<p>
    Autor:
    {{ post.user.username }}
</p>

<p>
    {{ post.content }}
</p>

{% if post.image %}
    <img src="/uploads/posts/{{ post.image }}" alt="">
{% endif %}

<p>
    Creado:
    {{ post.createdAt|date('d/m/Y H:i') }}

    {% if post.updatedAt %}
        (Editado {{ post.updatedAt|date('d/m/Y H:i') }})
    {% endif %}
</p>

<div class="post-actions">

    <a href="{{ path('post_like', {'id': post.id}) }}">
        👍 {{ post.likes }}
    </a>

    <a href="{{ path('post_dislike', {'id': post.id}) }}">
        👎 {{ post.dislikes }}
    </a>

    {% if app.user and (app.user == post.user or is_granted('ROLE_ADMIN')) %}

        <a href="{{ path('app_post_edit', {'id': post.id}) }}">
            ✏️ Editar
        </a>

        <form
            method="post"
            action="{{ path('app_post_delete', {'id': post.id}) }}"
            onsubmit="return confirm('¿Seguro que quieres borrar este post?');"
        >
            <input type="hidden"
                   name="_token"
                   value="{{ csrf_token('delete' ~ post.id) }}">

            <button type="submit" class="danger">
                🗑️ Eliminar
            </button>
        </form>

    {% endif %}

</div>

<hr>

<a href="{{ path('game_forum', {'slug': post.game.slug}) }}">
    Volver al foro
</a>

<hr>

<h2>Comentarios</h2>

{% for comment in comments %}

    <div>

        <strong>
            {{ comment.user.username }}
        </strong>

        <p>
            {{ comment.content }}
        </p>

        <small>
            {{ comment.createdAt|date('d/m/Y H:i') }}

            {% if comment.updatedAt %}
                (Editado {{ comment.updatedAt|date('d/m/Y H:i') }})
            {% endif %}
        </small>

        <br><br>

        <div class="post-actions">

            <a href="{{ path('comment_like', {'id': comment.id}) }}">
                👍 {{ comment.likes }}
            </a>

            <a href="{{ path('comment_dislike', {'id': comment.id}) }}">
                👎 {{ comment.dislikes }}
            </a>

            {% if app.user and (app.user == comment.user or is_granted('ROLE_ADMIN')) %}

                <a href="{{ path('comment_edit', {'id': comment.id}) }}">
                    ✏️ Editar
                </a>

                <a href="{{ path('comment_delete', {'id': comment.id}) }}" class="danger">
                🗑️ Eliminar
                </a>

            {% endif %}

        </div>

    </div>

    <hr>

{% else %}

    <p>No hay comentarios todavía.</p>

{% endfor %}

<h3>Escribir comentario</h3>

{{ form_start(form) }}
    {{ form_widget(form) }}
    <button>Enviar</button>
{{ form_end(form) }}

{% endblock %}