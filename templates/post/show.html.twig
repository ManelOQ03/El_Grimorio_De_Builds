{% extends 'base.html.twig' %}

{% block title %}
    {{ post.title }}
{% endblock %}

{% block banner %}
<div class="game-banner">
    <img src="/uploads/banners/{{ post.game.bannerImage }}" alt="{{ post.game.name }}">
</div>
{% endblock %}

{% block body %}

<div class="post-card">

    <span class="badge-game">
        🎮 {{ post.game.name }}
    </span>

    <h1>{{ post.title }}</h1>

    <p class="post-meta">

        👤 <strong>{{ post.user.username }}</strong>

        ·

        {{ post.createdAt|date('d/m/Y H:i') }}

        {% if post.updatedAt %}
            · ✏️ Editado {{ post.updatedAt|date('d/m/Y H:i') }}
        {% endif %}

    </p>

    <hr>

    <p class="post-content">

        {{ post.content }}

    </p>

    {% if post.image %}

        <img
            class="post-image"
            src="/uploads/posts/{{ post.image }}"
            alt=""
        >

    {% endif %}

    <div class="post-actions">

        <a href="{{ path('post_like', {'id': post.id}) }}">
            👍 {{ post.likes }}
        </a>

        <a href="{{ path('post_dislike', {'id': post.id}) }}">
            👎 {{ post.dislikes }}
        </a>

        {% if app.user and (app.user == post.user or is_granted('ROLE_ADMIN')) %}

            <a href="{{ path('app_post_edit', {'id': post.id}) }}">
                ✏️ Editar
            </a>

            <form
                method="post"
                action="{{ path('app_post_delete', {'id': post.id}) }}"
                style="display:inline;"
                onsubmit="return confirm('¿Eliminar publicación?');"
            >

                <input
                    type="hidden"
                    name="_token"
                    value="{{ csrf_token('delete' ~ post.id) }}"
                >

                <button class="danger">
                    🗑 Eliminar
                </button>

            </form>

        {% endif %}

    </div>

</div>

<br>

<a class="btn-small"
href="{{ path('game_forum', {'slug': post.game.slug}) }}">

← Volver al foro

</a>

<hr>

<h2>

💬 Comentarios ({{ comments|length }})

</h2>

{% for comment in comments %}

<div class="comment">

    <strong>

        👤 {{ comment.user.username }}

    </strong>

    <small>

        {{ comment.createdAt|date('d/m/Y H:i') }}

        {% if comment.updatedAt %}
            · ✏️ Editado
        {% endif %}

    </small>

    <p>

        {{ comment.content }}

    </p>

    <div class="post-actions">

        <a href="{{ path('comment_like', {'id': comment.id}) }}">
            👍 {{ comment.likes }}
        </a>

        <a href="{{ path('comment_dislike', {'id': comment.id}) }}">
            👎 {{ comment.dislikes }}
        </a>

        {% if app.user and (app.user == comment.user or is_granted('ROLE_ADMIN')) %}

            <a href="{{ path('comment_edit', {'id': comment.id}) }}">
                ✏️ Editar
            </a>

            <a href="{{ path('comment_delete', {'id': comment.id}) }}">
                🗑 Eliminar
            </a>

        {% endif %}

    </div>

</div>

{% else %}

<p>

Todavía no hay comentarios.

</p>

{% endfor %}

<div class="form-box">

<h2>

Añadir comentario

</h2>

{{ form_start(form) }}

{{ form_widget(form) }}

<button>

Publicar comentario

</button>

{{ form_end(form) }}

</div>

{% endblock %}