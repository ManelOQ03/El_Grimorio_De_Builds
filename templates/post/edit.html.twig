{% extends 'base.html.twig' %}

{% block title %}Edit Post{% endblock %}

{% block banner %}
    <div class="game-banner">
        <img
            src="/uploads/banners/{{ game.bannerImage }}"
            alt="{{ game.name }}"
        >
    </div>
{% endblock %}

{% block body %}
<div class="form-box">
    <h1>Editar la Publicación</h1>

    {{ include('post/_form.html.twig', {'button_label': 'Update'}) }}

    <a href="{{ path('app_post_index') }}">Vuelve a la lista</a>

    {{ include('post/_delete_form.html.twig') }}
</div>
{% endblock %}