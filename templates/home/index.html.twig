{% extends 'base.html.twig' %}

{% block title %}Grimorio De Builds{% endblock %}

{% block banner %}
    <div class="main-banner">
        <img src="{{ asset('images/banner-default.jpg') }}" alt="Grimorio de Builds">
    </div>
{% endblock %}

{% block body %}
<h1>Grimorio De Builds</h1>


<p>Selecciona un juego</p>

<div class="games-grid">

{% for game in games %}
    <a href="{{ path('game_show', {'slug': game.slug}) }}" class="game-link">
    <div class="card">

        <h2>{{ game.name }}</h2>

        {% if game.coverImage %}
            <img src="/uploads/games/{{ game.coverImage }}" alt="{{ game.name }}">
        {% endif %}

        <p>{{ game.description }}</p>

    </div>
</a>
{% endfor %}

</div>

<hr>

{% if quote %}
    <blockquote>
        "{{ quote.text }}"
        <br>
        <small>- {{ quote.author }}</small>
    </blockquote>
{% endif %}

{% endblock %}
