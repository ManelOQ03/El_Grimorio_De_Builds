{% extends 'base.html.twig' %}

{% block title %}New Build{% endblock %}

{% block banner %}
    <div class="game-banner">
        <img
            src="/uploads/banners/{{ game.bannerImage }}"
            alt="{{ game.name }}"
        >
    </div>
{% endblock %}

{% block body %}
<div class="form-box">

    <h1>Crear Nueva Build</h1>

    {{ include('build/_form.html.twig') }}

    <a href="{{ path('app_build_index') }}">Vuelve a la lista</a>
</div>

{% endblock %}
