{% extends 'base.html.twig' %}

{% block title %}
    {{ build.title }}
{% endblock %}

{% block banner %}
<div class="game-banner">
    <img
        src="/uploads/banners/{{ build.game.bannerImage }}"
        alt="{{ build.game.name }}"
    >
</div>
{% endblock %}

{% block body %}

<div class="build-show">

    <h1>{{ build.title }}</h1>

    <div class="build-meta">

        <span>🎮 {{ build.game.name }}</span>

        <span>👤 <a href="{{ path('user_profile', {'username': build.user.username}) }}"> {{ build.user.username }}
</a></span>

        <span>📅 {{ build.createdAt|date('d/m/Y H:i') }}</span>

    </div>

    {% if build.image %}

        <div class="build-image">

            <img
                src="/uploads/builds/{{ build.image }}"
                alt="{{ build.title }}"
            >

        </div>

    {% endif %}

    <div class="build-description">

        {{ build.description|nl2br }}

    </div>

    
    {% if app.user and (app.user == build.user or is_granted('ROLE_ADMIN')) %}

    <div class="post-actions">

        <a href="{{ path('app_build_edit', {'id': build.id}) }}">
            ✏️ Editar
        </a>

        <form
            method="post"
            action="{{ path('app_build_delete', {'id': build.id}) }}"
            onsubmit="return confirm('¿Seguro que quieres eliminar esta build?');"
        >

            <input
                type="hidden"
                name="_token"
                value="{{ csrf_token('delete' ~ build.id) }}"
            >

            <button
                type="submit"
                class="danger"
            >
                🗑️ Eliminar
            </button>

        </form>

    </div>

    <br>

<br>

{% endif %}

    <a
        class="btn-primary"
        href="{{ path('game_show', {'slug': build.game.slug}) }}"
    >
        ← Volver al juego
    </a>

</div>

{% endblock %}