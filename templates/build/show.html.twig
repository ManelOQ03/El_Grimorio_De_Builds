{% extends 'base.html.twig' %}

{% block title %}
    {{ build.title }}
{% endblock %}

{% block banner %}
    <div class="game-banner">
        <img
            src="/uploads/banners/{{ build.game.bannerImage }}"
            alt="{{ build.game.name }}"
        >
    </div>
{% endblock %}

{% block body %}

<h1>{{ build.title }}</h1>

<p>
    Juego:
    {{ build.game.name }}
</p>

<p>
    Autor:
    {{ build.user.username }}
</p>

<p>
    {{ build.description }}
</p>

<p>
    Creada:
    {{ build.createdAt|date('d/m/Y H:i') }}
</p>

<br>

{% if build.image %}
    <img src="/uploads/builds/{{ build.image }}" alt="">
{% endif %}

<a href="{{ path('game_show', {'slug': build.game.slug}) }}">
    Volver al juego
</a>

{% endblock %}
